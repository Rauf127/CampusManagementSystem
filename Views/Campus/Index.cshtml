@model IEnumerable<Student>

@{
    ViewData["Title"] = "Student Directory";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary"><i class="bi bi-people-fill"></i> Campus Directory</h2>
            <p class="text-muted">Manage all student records and departmental assignments.</p>
        </div>
        <a href="@Url.Action("AddStudent", "Campus")" class="btn btn-primary btn-lg shadow-sm">
            <i class="bi bi-plus-circle"></i> Enroll New Student
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-3">Name</th>
                            <th>ID</th>
                            <th>Email</th>
                            <th>Age</th>
                            <th>Dept.</th>
                            <th>Monthly Fee</th>
                            <th>Total Course Fee</th>
                            <th>Teacher</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3 fw-bold">@item.Name</td>
                                <td><span class="text-muted">#@item.Id</span></td>
                                <td>@item.Email</td>
                                <td>@item.Age</td>
                                <td>
                                    <span class="badge @(item.Department == "Science" ? "bg-info text-dark" : "bg-warning text-dark")">
                                        @item.Department
                                    </span>
                                </td>
                                <td class="text-success fw-bold">Rs. @item.MonthlyFees</td>
                                <td class="text-primary fw-bold">Rs. @item.TotalCourseFees</td>
                                <td>
                                    <span class="badge rounded-pill bg-success p-2 px-3">
                                        <i class="bi bi-person-badge"></i> @item.AssignTeacher
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a href="@Url.Action("EditStudent", "Campus", new { id = item.Id })"
                                           class="btn btn-outline-info btn-sm">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <a href="@Url.Action("DeleteStudent", "Campus", new { id = item.Id })"
                                           class="btn btn-outline-danger btn-sm"
                                           onclick="return confirm('Kya aap waqai is record ko delete karna chahte hain?')">
                                            <i class="bi bi-trash"></i> Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <h4 class="text-muted">No students found. Start by adding one!</h4>
        </div>
    }
</div>