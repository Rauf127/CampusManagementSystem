@model Campus_Management_System.Models.Student

@{
    ViewData["Title"] = "Add Student";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h3 class="mb-0"><i class="bi bi-person-plus-fill"></i> Student Admission Form</h3>
                </div>

                <div class="card-body p-4">
                    <form method="post">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Full Name</label>
                            <input asp-for="Name" class="form-control" placeholder="e.g. Abdul Rauf" required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold">Email Address</label>
                            <input asp-for="Email" class="form-control" placeholder="example@gmail.com" required />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Age" class="form-label fw-bold">Age</label>
                                <input asp-for="Age" class="form-control" placeholder="Age" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Department" class="form-label fw-bold">Department</label>
                                <select asp-for="Department" class="form-select" required>
                                    <option value="">-- Select --</option>
                                    <option value="Science">Science</option>
                                    <option value="Arts">Arts</option>
                                </select>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg shadow-sm">
                                <i class="bi bi-check-circle"></i> Submit Student Data
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-3 text-muted">
                <small>© 2026 Campus Management System - Secure Data Entry</small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}